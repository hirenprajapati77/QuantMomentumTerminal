# Fyers API Configuration
FYERS_APP_ID=your_fyers_app_id_here
FYERS_SECRET_ID=your_fyers_secret_id_here
FYERS_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Database & Cache URLs (Docker compose defaults shown)
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/nse_scanner
REDIS_URL=redis://redis:6379/0

# Application Configuration
LOG_LEVEL=INFO
DATA_DIR=./data

# Security Configuration
SETTINGS_PIN=1234
SECRET_KEY=yoursecretkeyhere

# Observability Alerts
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
